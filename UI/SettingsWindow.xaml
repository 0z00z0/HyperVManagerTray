<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HyperVManagerTray.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- Issue #23: the flat single-scroll card list became an in-box NavigationView with left-nav
         categories (General / Managed VMs / Network / Adapters / Maintenance / About). Zero new
         dependencies — the plain WinUI NavigationView plus the same code-built card idiom every other
         window in this app uses (BuildXxxSection in code-behind fills the per-category panels). The
         window stays a real titled, resizable, taskbar-visible window (NOT the borderless auto-dismiss
         tray popup): it must stay open while the user edits and alt-tabs away. -->
    <NavigationView x:Name="Nav"
                    IsSettingsVisible="False"
                    IsBackButtonVisible="Collapsed"
                    IsTabStop="False"
                    PaneDisplayMode="Left"
                    SelectionChanged="OnNavSelectionChanged">

        <!-- Let the Mica BaseAlt backdrop show through instead of the control painting its own lighter
             pane/top strip over it (same treatment as the sibling app's SettingsWindow). The selected-item
             highlight is a separate brush and is untouched. -->
        <NavigationView.Resources>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
            <!-- The left-pane item template wraps the Icon in a Viewbox bound to
                 NavigationViewItemOnLeftIconBoxHeight (default 16px), which would scale the two-tone
                 ImageIcons down to ~16px. Alias that theme resource to NavIconSize so the icon box and
                 every ImageIcon W/H stay in lockstep — mirrors the sibling app's Settings nav. -->
            <x:Double x:Key="NavIconSize">28</x:Double>
            <StaticResource x:Key="NavigationViewItemOnLeftIconBoxHeight" ResourceKey="NavIconSize"/>
        </NavigationView.Resources>

        <!-- Two-tone SVG nav icons (product blue line + green accent) rather than monochrome Segoe
             glyphs — shown via ImageIcon/SvgImageSource, matching the sibling app's Settings nav. -->
        <NavigationView.MenuItems>
            <NavigationViewItem Content="General" Tag="General" IsSelected="True">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/general.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Managed VMs" Tag="Vms">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/vms.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Network" Tag="Network">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/network.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Adapters" Tag="Adapters">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/adapters.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Maintenance" Tag="Maintenance">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/maintenance.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="About" Tag="About">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/about.svg" Width="{StaticResource NavIconSize}" Height="{StaticResource NavIconSize}"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- App-identity footer, bottom-left of the pane — product icon + name + running version (the
             version is filled in the ctor from AppInfo, never hard-coded).

             Issue #35: the icon is the PLATED product icon (Assets\AppIcon.png — the same face the exe,
             taskbar and installer wear), NOT the flat tray glyph. The tray glyph's blue is one of four
             live STATUS colours, so a static copy of it in an identity block would imply a state this
             footer does not track (precisely what #37 landed to stop doing). The plate also keeps it from
             reading as a seventh, label-less nav row beneath the transparent-background nav SVGs above. -->
        <NavigationView.PaneFooter>
            <StackPanel Margin="0,4,0,4">
                <Border Height="1" Margin="16,0,16,8"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8"
                            Margin="16,4,16,12" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/AppIcon.png"
                           Width="36" Height="36" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HyperVManagerTray" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="VersionText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </NavigationView.PaneFooter>

        <ScrollViewer x:Name="RootScroll" Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="720" HorizontalAlignment="Left">
                <StackPanel x:Name="GeneralPanel"     Spacing="10"/>
                <StackPanel x:Name="VmsPanel"         Spacing="10" Visibility="Collapsed"/>
                <StackPanel x:Name="NetworkPanel"     Spacing="10" Visibility="Collapsed"/>
                <StackPanel x:Name="AdaptersPanel"    Spacing="10" Visibility="Collapsed"/>
                <StackPanel x:Name="MaintenancePanel" Spacing="10" Visibility="Collapsed"/>
                <StackPanel x:Name="AboutPanel"       Spacing="10" Visibility="Collapsed"/>
            </Grid>
        </ScrollViewer>
    </NavigationView>
</Window>
