<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HyperVManagerTray.UI.RenameAdapterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root">
        <StackPanel Padding="16,14,16,14" Spacing="8">
            <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold"
                       Text="Rename Network Adapter"/>

            <TextBlock x:Name="WarningText" FontSize="11" TextWrapping="Wrap"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"/>

            <TextBlock FontSize="11" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Current description"/>
            <TextBlock x:Name="CurrentText" FontSize="12" TextWrapping="Wrap"
                       IsTextSelectionEnabled="True"/>

            <TextBlock FontSize="11" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="New name"/>
            <TextBox x:Name="InputBox" FontSize="12"/>

            <Grid ColumnSpacing="8" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ResetBtn" Grid.Column="0"
                        Content="Reset" FontSize="11" HorizontalAlignment="Stretch"/>
                <Button x:Name="CancelBtn" Grid.Column="1"
                        Content="Cancel" FontSize="11" HorizontalAlignment="Stretch"/>
                <Button x:Name="RenameBtn" Grid.Column="2"
                        Content="Rename" FontSize="11" HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
